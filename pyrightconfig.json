{
    "include": [
        "src/**/*.py",
        "src/**/*.pyi"
    ],
    "exclude": [
        ".git",
        ".venv",
        "**/build",
        "**/node_modules",
        "**/__pycache__",
        "**/*.D",
        "**/*.inp",
        "**/.*",
    ],
    "ignore": [
        "**/.*",
        "**/*.vtu",
        "**/*.log",
        ".mypy_cache/",
        ".deps"
    ],
    "autoSearchPaths": false,
    "importFormat": "relative",
    "autoFormatStrings": true,
    "autoImportCompletions": true,
    "completeFunctionParens": true,
    "diagnosticMode": "workspace",
    "typeCheckingMode": "strict",
    "typeEvaluation.deprecateTypingAliases": true,
    "typeEvaluation.strictDictionaryInference": true,
    "typeEvaluation.strictListInference": true,
    "typeEvaluation.strictSetInference": true,
    "enableColorPicker": false,
    "enablePytestSupport": false,
    "includeAliasesFromUserFiles": true,
    "typeEvaluation.disableBytesTypePromotions": true,
    "userFileIndexingLimit": 2000,
    "enableParallelIndexing": false,
    "reportMissingTypeStubs": "none",
}